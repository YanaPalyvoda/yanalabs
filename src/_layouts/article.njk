---
layout: base.njk
---
<article class="article-page">
  <div class="container">

    <nav class="breadcrumb" aria-label="Fil d'Ariane">
      <a href="/">Accueil</a>
      <span>›</span>
      <a href="/actualites/">Actualités</a>
      <span>›</span>
      <span>{{ title }}</span>
    </nav>

    <header class="article-header">
      {% if categorie %}<span class="badge">{{ categorie }}</span>{% endif %}
      <h1>{{ title }}</h1>
      {% if description %}<p class="article-description">{{ description }}</p>{% endif %}
      <div class="article-meta">
        <time datetime="{{ page.date | htmlDateString }}">{{ page.date | readableDate }}</time>
        {% if temps_lecture %}<span>·</span><span>{{ temps_lecture }} min de lecture</span>{% endif %}
      </div>
    </header>

    {% if image %}
      <div class="article-hero-image">
        <!-- Modifications 20260424 par Openclaw -->
        <!-- <img src="{{ image }}" alt="{{ title }}" loading="eager"/> -->
        <img src="{{ image }}" alt="{{ title }}" loading="eager" decoding="async" />
      </div>
    {% endif %}

    <div class="article-layout">

      {% if sommaire %}
        <aside class="article-toc">
          <p class="toc-title">Sommaire</p>
          <ul>
            {% for item in sommaire %}
              <li><a href="#{{ item.slug }}">{{ item.titre }}</a></li>
            {% endfor %}
          </ul>
        </aside>
      {% endif %}

      <div class="article-body">
        {{ content | safe }}

        <div class="article-cta">
          <h3>Prêt à automatiser votre activité ?</h3>
          <p>Réservez un audit offert et découvrez combien d'heures vous pouvez récupérer chaque semaine.</p>
          <a href="https://calendly.com/yanalabs/30min" target="_blank" rel="noopener" class="btn btn-gradient">
            Je réserve mon appel découverte
          </a>
        </div>

      </div>
    </div>
    {# ——— NAVIGATION PREV/NEXT ——— #}
        <nav class="article-nav">
          {%- set previousPost = collections.articles | getPreviousCollectionItem %}
          {%- set nextPost = collections.articles | getNextCollectionItem %}
          {% if previousPost %}
            <a href="{{ previousPost.url }}" class="article-nav-link prev">
              <span>← Article précédent</span>
              <strong>{{ previousPost.data.title }}</strong>
            </a>
          {% endif %}
          {% if nextPost %}
            <a href="{{ nextPost.url }}" class="article-nav-link next">
              <span>Article suivant →</span>
              <strong>{{ nextPost.data.title }}</strong>
            </a>
          {% endif %}
        </nav>

    {# Modifications 20260424 par Openclaw — 2 </div> orphelins commentés (HTML cassé) #}
    {# </div> #}
    {# </div> #}

    {# ——— ARTICLES SIMILAIRES ——— #}
    {# Modifications 20260424 par Openclaw — filtre excludeUrl pour toujours avoir 3 articles #}
    {# {% set similaires = collections.articles | reverse | limit(3) %} #}
    {% set similaires = collections.articles | reverse | excludeUrl(page.url, 3) %}
    {% if similaires.length %}
      <section class="articles-similaires">
        <h2>Continuer la lecture</h2>
        <div class="steps-grid">
          {% for post in similaires %}
            {% if post.url != page.url %}
              <a href="{{ post.url }}" class="step-card" style="text-decoration:none;">
                <time style="font-size:12px; color:var(--color-accent-soft); display:block; margin-bottom:8px;">
                  {{ post.date | readableDate }}
                </time>
                {% if post.data.categorie %}
                  <span class="badge" style="font-size:11px; margin-bottom:8px;">
                    {{ post.data.categorie }}
                  </span>
                {% endif %}
                <h3>{{ post.data.title }}</h3>
                {% if post.data.description %}
                  <p>{{ post.data.description }}</p>
                {% endif %}
              </a>
            {% endif %}
          {% endfor %}
        </div>
      </section>
    {% endif %}

  </div>
</article>
