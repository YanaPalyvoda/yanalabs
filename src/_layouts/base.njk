  <!-- Modifications 20260424 par Openclaw -->
  <!-- <meta property="og:image" content="https://yanalabs.fr/images/og-image.jpg"/> -->
  <meta property="og:image" content="{{ 'https://yanalabs.fr' + image if image else 'https://yanalabs.fr/images/og-image.jpg' }}"/>
  <meta property="og:locale" content="fr_FR"/>
  <meta property="og:image:width" content="1200"/>
  <meta property="og:image:height" content="630"/>
  <meta property="og:image:type" content="image/jpeg"/>

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image"/>
  <meta name="twitter:title" content="{{ title if title else 'YanaLabs' }}"/>
  <meta name="twitter:description" content="{{ description if description else 'Automatisation no-code pour TPE/PME' }}"/>
  <!-- Modifications 20260424 par Openclaw -->
  <!-- <meta name="twitter:image" content="https://yanalabs.fr/images/og-image.jpg"/> -->
  <meta name="twitter:image" content="{{ 'https://yanalabs.fr' + image if image else 'https://yanalabs.fr/images/og-image.jpg' }}"/>

  <!-- Favicon -->
