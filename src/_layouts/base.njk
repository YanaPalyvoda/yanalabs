<!DOCTYPE html>
<html lang="fr">
<head>
  <!-- Charset & responsive -->
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

  <!-- Title & SEO -->
  <title>{{ title if title else "YanaLabs — Automatisation No-Code pour TPE/PME" }}</title>
  <meta name="description" content="{{ description if description else 'YanaLabs automatise vos tâches répétitives grâce au no-code (Make, Airtable). Solutions sur-mesure pour TPE et PME en Île-de-France. Audit gratuit et sans engagement.' }}"/>
  <meta name="robots" content="{{ 'noindex, follow' if noindex else 'index, follow' }}"/>
  <meta name="author" content="{{ 'Yana Palyvoda — YanaLabs' if layout != 'article.njk' else 'Yana Palyvoda' }}" />

  <!-- Google Search Console -->
  <meta name="google-site-verification" content="4tieIsBN1eoDg9byDy2QbCu4C-a-igZP4kb3Ji6GqEc"/>

  <!-- Canonical -->
  <link rel="canonical" href="https://yanalabs.fr{{ page.url }}"/>

  <!-- Open Graph (Facebook, LinkedIn) -->
