  {% if faqPage %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Faut-il des compétences techniques ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Aucune expertise technique n'est nécessaire. Nos solutions sont intuitives et prêtes à l'emploi. Vous bénéficiez d'une formation sur mesure et d'un accompagnement continu pour démarrer en toute sérénité."
        }
      },
      {
        "@type": "Question",
        "name": "Et si j'ai un problème après la mise en place, je suis tout seul ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Non, vous bénéficiez d'un suivi personnalisé avec un mois de maintenance inclus et un support continu."
        }
      },
      {
        "@type": "Question",
        "name": "Est-ce que ça coûte cher de tout automatiser ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Le coût est adapté à vos besoins. Le retour sur investissement est rapide grâce aux heures économisées chaque semaine."
        }
      },
      {
        "@type": "Question",
        "name": "Combien de temps ça va me prendre ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "La mise en place prend 1 à 3 semaines. Ensuite, les automatisations tournent seules."
        }
      },
      {
        "@type": "Question",
        "name": "Par où commencer ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "La méthode est simple : repérer les actions répétées plusieurs fois par jour, les saisies d'informations identiques, et les étapes déclenchées à chaque fois par le même événement."
        }
      }
    ]
  }
  </script>
