<!DOCTYPE html>
<html lang="fr">
<head>
  <!-- Charset & responsive -->
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

  <!-- Title & SEO -->
  <title>{{ title if title else "YanaLabs — Automatisation No-Code pour TPE/PME" }}</title>
  <meta name="description" content="{{ description if description else 'YanaLabs automatise vos tâches répétitives grâce au no-code (Make, Airtable). Solutions sur-mesure pour TPE et PME en Île-de-France. Audit gratuit et sans engagement.' }}"/>
  <meta name="robots" content="{{ 'noindex, follow' if noindex else 'index, follow' }}"/>
  <meta name="author" content="{{ 'Yana Palyvoda — YanaLabs' if layout != 'article.njk' else 'Yana Palyvoda' }}" />

  <!-- Canonical -->
  <link rel="canonical" href="https://yanalabs.fr{{ page.url }}"/>

  <!-- Open Graph (Facebook, LinkedIn) -->
  <meta property="og:title" content="{{ title if title else 'YanaLabs — Automatisation No-Code' }}"/>
  <meta property="og:description" content="{{ description if description else 'Gagnez du temps avec des automatisations no-code sur mesure.' }}"/>
  <meta property="og:type" content="{{ 'article' if layout == 'article.njk' else 'website' }}"/>
  <meta property="og:url" content="https://yanalabs.fr{{ page.url }}"/>
  <meta property="og:site_name" content="YanaLabs"/>
  <!-- Modifications 20260424 par Openclaw -->
  <!-- <meta property="og:image" content="https://yanalabs.fr/images/og-image.jpg"/> -->
  <meta property="og:image" content="{{ 'https://yanalabs.fr' + image if image else 'https://yanalabs.fr/images/og-image.jpg' }}"/>
  <meta property="og:locale" content="fr_FR"/>

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image"/>
  <meta name="twitter:title" content="{{ title if title else 'YanaLabs' }}"/>
  <meta name="twitter:description" content="{{ description if description else 'Automatisation no-code pour TPE/PME' }}"/>
  <!-- Modifications 20260424 par Openclaw -->
  <!-- <meta name="twitter:image" content="https://yanalabs.fr/images/og-image.jpg"/> -->
  <meta name="twitter:image" content="{{ 'https://yanalabs.fr' + image if image else 'https://yanalabs.fr/images/og-image.jpg' }}"/>

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/images/Favicon.png"/>
  <link rel="apple-touch-icon" href="/images/Favicon.png"/>

  <!-- Modifications 20260424 par Openclaw -->
  <!-- Performance (fonts) — dns-prefetch doit précéder preconnect -->
  <!-- Ancien ordre :
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  (dns-prefetch était en bas, après le CSS — ordre incorrect)
  -->
  <link rel="dns-prefetch" href="//fonts.googleapis.com">
  <link rel="dns-prefetch" href="//fonts.gstatic.com">
  <link rel="dns-prefetch" href="//cdnjs.cloudflare.com">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preconnect" href="https://cdnjs.cloudflare.com">

  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Onest:wght@400;500;600;700&display=swap" rel="stylesheet">

  <!-- CSS -->
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body>

  <!-- ======================================================
       NAVIGATION
  ======================================================= -->
  <nav class="navbar" id="navbar">
    <div class="navbar-inner">
      <a class="navbar-logo" href="/">
        <!-- Modifications 20260424 par Openclaw -->
        <!-- <img src="/images/logoNew.png" alt="YanaLabs" height="58" /> -->
        <img src="/images/logoNew.png" alt="YanaLabs" width="111" height="50" />
      </a>
      <ul class="navbar-links">
        <li><a href="/#notre-demarche">Notre démarche</a></li>
        <li><a href="/#features">Services</a></li>
        <li><a href="/#about">À propos</a></li>
        <li><a href="/#faq">FAQ</a></li>
        <li><a href="/actualites/">Actualités</a></li>
      </ul>
      <a class="btn-nav" href="https://calendly.com/yanalabs/30min" target="_blank" rel="noopener">
        <span>Je réserve mon appel découverte</span>
      </a>
      <button class="hamburger" id="hamburger" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div class="mobile-menu" id="mobileMenu">
    <button class="mobile-menu-close" id="mobileClose" aria-label="Fermer">✕</button>
    <a href="/#notre-demarche">Notre démarche</a>
    <a href="/#features">Services</a>
    <a href="/#about">À propos</a>
    <a href="/#faq">FAQ</a>
    <!-- Modifications 20260424 par Openclaw -->
    <!-- <a href="/actualites">Actualités</a> -->
    <a href="/actualites/">Actualités</a>
    <a href="https://calendly.com/yanalabs/30min" target="_blank" class="btn btn-gradient">Nous contacter</a>
  </div>
  <main>
    {{ content | safe }}
  </main>
  <!-- ======================================================
       FOOTER
  ======================================================= -->
  <footer>
    <div class="container">
      <div class="footer-inner">
        <div>
          <a class="footer-logo" href="/">
            <img src="/images/logoNew.png" alt="YanaLabs" />
          </a>
          <p class="footer-tagline">Votre agence d'automatisation préférée</p>
        </div>
        <ul class="footer-links">
          <li><a href="/#notre-demarche">Notre démarche</a></li>
          <li><a href="/#features">Services</a></li>
          <li><a href="/#about">À propos</a></li>
          <li><a href="/#faq">FAQ</a></li>
          <li><a href="/actualites/">Actualités</a></li>
        </ul>
        <span class="footer-copy">© 2026. Tous droits réservés.</span>
      </div>
      <div class="footer-bottom">
        <a href="/legal/mentions-legales/">Mentions Légales</a>
        <span class="footer-sep">·</span>
        <a href="/legal/politique-confidentialite/">Politique de confidentialité</a>
        <span class="footer-sep">·</span>
        <a href="/legal/politique-cookies/">Cookies</a>
      </div>
    </div>
  </footer>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
  <script src="/js/main.js"></script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "YanaLabs",
    "url": "https://yanalabs.fr",
    "description": "Agence d'automatisation no-code pour TPE/PME en Île-de-France",
    "inLanguage": "fr-FR",
    "publisher": {
      "@type": "Organization",
      "name": "YanaLabs"
    }
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "YanaLabs",
    "url": "https://yanalabs.fr",
    "logo": "https://yanalabs.fr/images/Favicon.png",
    "email": "automation@yanalabs.fr",
    "telephone": "+33-695580203",
    "foundingDate": "2025",
    "sameAs": [
      "https://www.linkedin.com/company/yanalabs",
      "https://www.linkedin.com/in/yana-palyvoda"
    ]
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "YanaLabs",
    "url": "https://yanalabs.fr",
    "logo": "https://yanalabs.fr/images/Favicon.png",
    "image": "https://yanalabs.fr/images/og-image.jpg",
    "description": "YanaLabs automatise les tâches répétitives des TPE et PME grâce au no-code (Make, Airtable). Solutions sur-mesure en Île-de-France.",
    "telephone": "+33-695580203",
    "email": "automation@yanalabs.fr",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Neuilly-Plaisance",
      "addressRegion": "Île-de-France",
      "addressCountry": "FR"
    },
    "areaServed": {
      "@type": "State",
      "name": "Île-de-France"
    },
    "priceRange": "€€",
    "openingHoursSpecification": {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
      "opens": "09:00",
      "closes": "18:00"
    }
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Automatisation No-Code",
    "name": "Automatisation de tâches répétitives pour TPE/PME",
    "provider": {
      "@type": "Organization",
      "name": "YanaLabs",
      "url": "https://yanalabs.fr"
    },
    "areaServed": {
      "@type": "State",
      "name": "Île-de-France"
    },
    "description": "Automatisation sur-mesure de vos processus métier : gestion des prospects, envoi de devis, relances impayés, connexion d'outils (Gmail, Excel, CRM) et tableaux de bord centralisés.",
    "offers": {
      "@type": "Offer",
      "availability": "https://schema.org/InStock",
      "priceCurrency": "EUR",
      "price": "0",
      "description": "Audit gratuit et sans engagement"
    }
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Yana",
    "jobTitle": "Fondatrice",
    "image": "https://yanalabs.fr/images/aboutme.jpeg",
    "url": "https://yanalabs.fr/#about",
    "sameAs": [
      "https://www.linkedin.com/in/yana-palyvoda"
    ],
    "worksFor": {
      "@type": "Organization",
      "name": "YanaLabs",
      "url": "https://yanalabs.fr"
    },
    "knowsAbout": ["Automatisation no-code", "Make", "Airtable", "Transformation digitale TPE PME"],
    "alumniOf": ["Enedis", "Crédit Agricole CIB"],
    "address": {
      "@type": "PostalAddress",
      "addressRegion": "Île-de-France",
      "addressCountry": "FR"
    }
  }
</script>
  {% if faqPage %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Je n'y connais rien en informatique, est-ce que je vais savoir l'utiliser ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Absolument ! Nos solutions sont conçues pour être intuitives. Nous vous formons et restons disponibles pour toute question."
        }
      },
      {
        "@type": "Question",
        "name": "Et si j'ai un problème après la mise en place, je suis tout seul ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Non, vous bénéficiez d'un suivi personnalisé avec un mois de maintenance inclus et un support continu."
        }
      },
      {
        "@type": "Question",
        "name": "Est-ce que ça coûte cher de tout automatiser ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Le coût est adapté à vos besoins. Le retour sur investissement est rapide grâce aux heures économisées chaque semaine."
        }
      },
      {
        "@type": "Question",
        "name": "Combien de temps ça va me prendre ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "La mise en place prend 1 à 2 semaines. Ensuite, les automatisations tournent seules."
        }
      },
      {
        "@type": "Question",
        "name": "Est-ce que mes données clients sont en sécurité ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Oui, nous utilisons uniquement des outils conformes RGPD. Vos données restent sous votre contrôle."
        }
      }
    ]
  }
  </script>
  {% endif %}
  {% if layout == "article.njk" %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": "{{ title }}",
    "description": "{{ description }}",
    "datePublished": "{{ page.date | htmlDateString }}",
    "dateModified": "{{ updated | htmlDateString if updated else page.date | htmlDateString }}",
    "url": "https://yanalabs.fr{{ page.url }}",
    "inLanguage": "fr-FR",
    "articleSection": "{{ categorie if categorie else 'Automatisation No-Code' }}",
    "wordCount": {{ content | wordCount }},
    "keywords": "{{ tags | join(', ') if tags else (categorie if categorie else 'automatisation no-code, TPE PME') }}",
    {% if image %}"image": "https://yanalabs.fr{{ image }}",{% endif %}
    "speakable": {
      "@type": "SpeakableSpecification",
      "cssSelector": [".article-description", ".article-body blockquote", ".article-toc", ".article-body h2"]
    },
    "author": {
      "@type": "Person",
      "name": "Yana Palyvoda",
      "url": "https://yanalabs.fr/#about",
      "sameAs": "https://www.linkedin.com/in/yana-palyvoda"
    },
    "publisher": {
      "@type": "Organization",
      "name": "YanaLabs",
      "url": "https://yanalabs.fr",
      "logo": {
        "@type": "ImageObject",
        "url": "https://yanalabs.fr/images/Favicon.png"
      }
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "https://yanalabs.fr{{ page.url }}"
    }
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Accueil",
        "item": "https://yanalabs.fr/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Actualités",
        "item": "https://yanalabs.fr/actualites/"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": "{{ title }}",
        "item": "https://yanalabs.fr{{ page.url }}"
      }
    ]
  }
  </script>
  {% if faq %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {% for item in faq %}
      {
        "@type": "Question",
        "name": "{{ item.q }}",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "{{ item.a }}"
        }
      }{% if not loop.last %},{% endif %}
      {% endfor %}
    ]
  }
  </script>
  {% endif %}
{% endif %}
</body>
</html>
