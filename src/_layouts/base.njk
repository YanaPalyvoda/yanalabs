  <!-- Modifié par Claude Code le 20260503 — CSS en premier pour découverte anticipée par le navigateur -->
  <link rel="preload" href="/css/style.css" as="style"/>
  <link rel="stylesheet" href="/css/style.css"/>

  <!-- Modifications 20260424 par Openclaw -->
  <!-- Performance (fonts) — dns-prefetch doit précéder preconnect -->
  <!-- Ancien ordre :
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  (dns-prefetch était en bas, après le CSS — ordre incorrect)
  -->
  <link rel="dns-prefetch" href="//fonts.googleapis.com">
  <link rel="dns-prefetch" href="//fonts.gstatic.com">
  <link rel="dns-prefetch" href="//cdnjs.cloudflare.com">
  <link rel="dns-prefetch" href="//calendly.com">
  <link rel="dns-prefetch" href="//www.googletagmanager.com">
  <link rel="dns-prefetch" href="//www.google-analytics.com">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preconnect" href="https://cdnjs.cloudflare.com">

  <!-- Google Fonts - async pour ne pas bloquer le rendu (PageSpeed) -->
  <link rel="preload"
        href="https://fonts.googleapis.com/css2?family=Onest:wght@400;500;600;700&display=swap"
        as="style"
        onload="this.onload=null;this.rel='stylesheet'">
  <noscript>
    <link rel="stylesheet"
          href="https://fonts.googleapis.com/css2?family=Onest:wght@400;500;600;700&display=swap">
