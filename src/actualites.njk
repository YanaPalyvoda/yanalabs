---
layout: base.njk
title: "Actualités — YanaLabs"
description: "Conseils pratiques sur l'automatisation no-code pour TPE/PME."
---

<section class="actualites">
  <div class="container">

    <div class="section-header reveal">
      <span class="badge">Blog</span>
      <h1 style="font-size:62px; font-weight:500; letter-spacing:-0.04em;
                  color:var(--color-primary); margin-bottom:16px;">
        Actualités
      </h1>
      <p>Conseils, cas d'usage et tendances de l'automatisation no-code pour TPE/PME.</p>
    </div>

    {% set posts = collections.articles | reverse %}

    {% if posts.length == 0 %}
      <p style="text-align:center; color:var(--color-accent-soft); margin-top:40px;">
        Aucun article pour le moment, revenez bientôt !
      </p>

    {% else %}
      <div class="steps-grid">
        {% for post in posts %}
          <a href="{{ post.url }}" class="step-card reveal" style="text-decoration:none;">

            <div style="display:flex; justify-content:space-between;
                        align-items:center; margin-bottom:12px;">
              {% if post.data.categorie %}
                <span class="badge" style="font-size:11px; margin-bottom:0;">
                  {{ post.data.categorie }}
                </span>
              {% endif %}
              <time style="font-size:12px; color:var(--color-accent-soft);">
                {{ post.date | readableDate }}
              </time>
            </div>

            <h2 style="font-size:18px; font-weight:600;
                        color:var(--color-cta-purple); margin-bottom:12px;">
              {{ post.data.title }}
            </h2>

            {% if post.data.description %}
              <p style="font-size:15px; color:var(--color-secondary);
                         line-height:1.65; margin-bottom:12px;">
                {{ post.data.description }}
              </p>
            {% endif %}

            {% if post.data.temps_lecture %}
              <p style="font-size:13px; color:var(--color-accent-soft);">
                {{ post.data.temps_lecture }} min de lecture
              </p>
            {% endif %}

            <p style="font-size:14px; font-weight:600;
                       color:var(--color-cta-purple); margin-top:16px;">
              Lire l'article →
            </p>

          </a>
        {% endfor %}
      </div>
    {% endif %}

  </div>
</section>