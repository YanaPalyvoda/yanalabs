<div class="video-section">

  <div class="badge-gratuit">
    <div class="badge-dot"></div>
    {{ badgeText | default("Audit gratuit · Sans engagement") }}
  </div>

  <div class="video-wrapper">
    <video
      id="yanaVideo"
      autoplay
      muted
      loop
      playsinline
      src="{{ videoSrc | default('/assets/video-yanalabs.mp4') }}">
    </video>

    <button class="sound-btn" id="soundBtn" aria-label="Activer le son" title="Activer / couper le son">
      <svg id="iconMuted" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
        <line x1="23" y1="9" x2="17" y2="15"/>
        <line x1="17" y1="9" x2="23" y2="15"/>
      </svg>
      <svg id="iconSound" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none">
        <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
        <path d="M19.07 4.93a10 10 0 0 1 0 14.14"/>
        <path d="M15.54 8.46a5 5 0 0 1 0 7.07"/>
      </svg>
    </button>

    <div class="video-cta-overlay">
      <div class="cta-content">
        <div class="cta-text">
          {% if headline %}<div class="cta-headline">{{ headline | safe }}</div>{% endif %}
          {% if subline %}<div class="cta-sub">{{ subline }}</div>{% endif %}
        </div>
        <a class="cta-btn" href="{{ ctaUrl | default('https://www.yanalabs.fr') }}" target="_blank" rel="noopener">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
          {{ ctaLabel | default("Demander mon audit") }}
        </a>
      </div>
    </div>

  </div>

  {% if caption %}
    <p class="video-caption">{{ caption }}</p>
  {% endif %}

</div>
